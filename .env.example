# ============================================
# MarketMind Environment Configuration
# ============================================

# Django settings
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,*

# Database settings
DATABASE_NAME=marketmind_db
DATABASE_USER=marketmind_user
DATABASE_PASSWORD=marketmind_password
DATABASE_HOST=db
DATABASE_PORT=5432

# Docker Ports
WEB_PORT=8300
POSTGRES_PORT=5433

# Alpha Vantage API key (optional but recommended for dividend features)
# Enables full dividend history with payment dates, accurate Div Growth 1Y/5Y,
# and the Chowder Number. Free tier: 25 calls/day (enough for ~25 tickers per sync).
# Get a free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Finnhub API key (reserved for future use, not currently active)
FINNHUB_API_KEY=

# Email settings (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
